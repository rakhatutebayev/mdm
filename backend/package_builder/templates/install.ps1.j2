#Requires -Version 5.1
<#
.SYNOPSIS
    NOCKO MDM Agent Enrollment Script
.DESCRIPTION
    Enrolls this Windows device into NOCKO MDM.
    Runs automatically at first boot after MSI installation.
    Safe to run multiple times (idempotent via UDID check on server).
#>

[CmdletBinding()]
param(
    [string]$ServerUrl  = "{{ server_url }}",
    [string]$Token      = "{{ enrollment_token }}",
    [string]$CustomerID = "{{ customer_id }}",
    [string]$APIBase    = "{{ server_url }}/api/v1"
)

$ErrorActionPreference = "Stop"
$LogFile = "{{ log_dir }}\enroll.log"

function Write-Log($msg) {
    $ts = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    "$ts  $msg" | Tee-Object -FilePath $LogFile -Append | Write-Host
}

function Get-SafeValue($cmd) {
    try { & $cmd } catch { "UNKNOWN" }
}

# ── Helpers ───────────────────────────────────────────────────────────────────
function Get-SerialNumber { try { (Get-WmiObject Win32_BIOS).SerialNumber } catch { "UNKNOWN" } }
function Get-UDID {
    try {
        $uuid = (Get-WmiObject Win32_ComputerSystemProduct).UUID
        if ($uuid -and $uuid -ne "UNKNOWN" -and $uuid -ne "To Be Filled By O.E.M.") { return ($uuid -replace "-", "") }
    } catch {}
    return [System.Guid]::NewGuid().ToString("N").ToUpper()
}
function Get-OSVersion { try { $os = Get-WmiObject Win32_OperatingSystem; "$($os.Caption) $($os.Version)" } catch { "Windows Unknown" } }
function Get-Architecture { if ([Environment]::Is64BitOperatingSystem) { "x64" } else { "x86" } }
function Get-Manufacturer { try { (Get-WmiObject Win32_ComputerSystem).Manufacturer } catch { "Unknown" } }
function Get-ModelName    { try { (Get-WmiObject Win32_ComputerSystem).Model }        catch { "Unknown" } }

function Get-NetworkInfo {
    try {
        $nic = Get-WmiObject Win32_NetworkAdapterConfiguration |
               Where-Object { $_.IPEnabled -and $_.DefaultIPGateway } |
               Select-Object -First 1
        if ($nic) {
            # Force array with @() so [0] returns the first *element*, not first *character*
            $ipv4 = @($nic.IPAddress | Where-Object { $_ -notmatch ":" }) | Select-Object -First 1
            return @{
                ip_address      = if ($ipv4) { $ipv4 } else { "" }
                mac_address     = $nic.MACAddress
                hostname        = $env:COMPUTERNAME
                wifi_ssid       = ""
                connection_type = "Ethernet"
                dns_server      = if ($nic.DNSServerSearchOrder) { $nic.DNSServerSearchOrder -join ", " } else { "" }
                default_gateway = if ($nic.DefaultIPGateway) { $nic.DefaultIPGateway[0] } else { "" }
            }
        }
    } catch {}
    return @{ ip_address = ""; mac_address = ""; hostname = $env:COMPUTERNAME; wifi_ssid = ""; connection_type = ""; dns_server = ""; default_gateway = "" }
}

# ── Ensure persistent config and log folder ───────────────────────────────────
$configDir = "{{ log_dir }}"
if (-not (Test-Path $configDir)) { New-Item -ItemType Directory -Force -Path $configDir | Out-Null }

Write-Log "=== NOCKO MDM Enrollment Starting ==="
Write-Log "ServerUrl : $ServerUrl"
Write-Log "CustomerID: $CustomerID"

# ── Verify installation files ─────────────────────────────────────────────────
$scriptDir = Split-Path -Parent $MyInvocation.MyCommand.Path
Write-Log "Install directory: $scriptDir"
if (-not (Test-Path "$scriptDir\install.ps1")) {
    Write-Log "ERROR: install.ps1 not found in $scriptDir. Installation may be corrupt."
    exit 1
}
Write-Log "Installation files verified OK."

# ── Clean up duplicate entries in Programs & Features ─────────────────────────
# Remove stale uninstall keys from previous broken installs (both 64-bit and WOW6432Node)
foreach ($regPath in @(
    "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall",
    "HKLM:\SOFTWARE\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall"
)) {
    if (Test-Path $regPath) {
        Get-ChildItem $regPath -ErrorAction SilentlyContinue | ForEach-Object {
            $displayName = (Get-ItemProperty $_.PSPath -ErrorAction SilentlyContinue).DisplayName
            if ($displayName -and $displayName -match "NOCKO MDM") {
                Write-Log "Removing stale uninstall entry: $displayName ($($_.PSChildName))"
                Remove-Item $_.PSPath -Recurse -Force -ErrorAction SilentlyContinue
            }
        }
    }
}

# ── Check privileges ─────────────────────────────────────────────────────────
$isAdmin = ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)
if (-not $isAdmin) {
    Write-Log "ERROR: Must run as Administrator. Re-launching elevated..."
    Start-Process powershell -Verb RunAs -ArgumentList "-NonInteractive -ExecutionPolicy Bypass -File `"$PSCommandPath`""
    exit 0
}

# ── Already enrolled? ─────────────────────────────────────────────────────────
$configFile = "$configDir\config.json"
if (Test-Path $configFile) {
    $existing = Get-Content $configFile | ConvertFrom-Json
    if ($existing.device_id -and $existing.server_url -eq $ServerUrl) {
        Write-Log "Already enrolled. device_id=$($existing.device_id). Running checkin..."
        try {
            Invoke-RestMethod -Uri "$APIBase/mdm/windows/checkin" -Method POST -ContentType "application/json" `
                -Body (ConvertTo-Json @{ device_id = $existing.device_id; agent_version = "1.0.0" }) | Out-Null
            Write-Log "Checkin OK."
        } catch { Write-Log "Checkin failed (non-fatal): $_" }
        exit 0
    }
}

# ── Collect device info ───────────────────────────────────────────────────────
$deviceName   = $env:COMPUTERNAME
$serial       = Get-SerialNumber
$udid         = Get-UDID
$osVersion    = Get-OSVersion
$arch         = Get-Architecture
$manufacturer = Get-Manufacturer
$model        = Get-ModelName
$network      = Get-NetworkInfo

Write-Log "Device    : $deviceName | Serial: $serial | OS: $osVersion"
Write-Log "Network   : IP=$($network.ip_address) MAC=$($network.mac_address)"

# ── Register with NOCKO MDM ───────────────────────────────────────────────────
Write-Log "Sending enrollment to $APIBase/mdm/windows/enroll ..."

$payload = @{
    customer_id       = $CustomerID
    enrollment_token  = $Token
    device_name       = $deviceName
    platform          = "Windows"
    device_type       = "Desktop"
    model             = $model
    manufacturer      = $manufacturer
    serial_number     = $serial
    udid              = $udid
    os_version        = $osVersion
    architecture      = $arch
    owner             = ""
    enrollment_method = "Agent"
    agent_version     = "1.0.0"
    network           = $network
    monitors          = @()
} | ConvertTo-Json -Depth 10

try {
    $response = Invoke-RestMethod `
        -Uri "$APIBase/mdm/windows/enroll" `
        -Method POST `
        -ContentType "application/json" `
        -Body $payload
    $deviceId = $response.device_id
    Write-Log "Enrollment OK. device_id=$deviceId status=$($response.status)"
} catch {
    Write-Log "ERROR: Enrollment failed: $_"
    if ($_.Exception.Response) {
        try {
            $stream = $_.Exception.Response.GetResponseStream()
            $reader = New-Object System.IO.StreamReader $stream
            Write-Log "Server response: $($reader.ReadToEnd())"
        } catch {}
    }
    # ── ROLLBACK: clean up partial state ──────────────────────────────────────
    Write-Log "Rolling back: removing partial config and scheduled task..."
    Remove-Item -Path $configFile -Force -ErrorAction SilentlyContinue
    Unregister-ScheduledTask -TaskName "{{ agent_display_name }} Check-In" -Confirm:$false -ErrorAction SilentlyContinue
    # Remove the RunOnce key so it doesn't re-trigger on next login
    Remove-ItemProperty -Path "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\RunOnce" -Name "NockoMDMEnroll" -Force -ErrorAction SilentlyContinue
    Write-Log "Rollback complete. Fix the issue and reinstall the agent."
    exit 1
}

# ── Save config ───────────────────────────────────────────────────────────────
@{
    server_url    = $ServerUrl
    token         = $Token
    customer_id   = $CustomerID
    device_id     = $deviceId
    agent_version = "1.0.0"
    installed_at  = (Get-Date -Format "o")
} | ConvertTo-Json | Set-Content -Path $configFile -Encoding UTF8
Write-Log "Config saved to $configFile"

# ── Register Scheduled Task (checkin every 15 min) ────────────────────────────
$checkinScript = @"
`$config = Get-Content '$configFile' | ConvertFrom-Json
try {
    # CPU — LoadPercentage can be null on some VMs (Parallels, Hyper-V)
    `$cpuRaw = (Get-WmiObject Win32_Processor | Measure-Object -Property LoadPercentage -Average).Average
    `$cpu    = if (`$cpuRaw -ne `$null) { [math]::Round([double]`$cpuRaw, 1) } else { `$null }

    `$os   = Get-WmiObject Win32_OperatingSystem
    `$ramTotalGB = [math]::Round([double]`$os.TotalVisibleMemorySize / 1MB, 2)
    `$ramUsedGB  = [math]::Round(([double]`$os.TotalVisibleMemorySize - [double]`$os.FreePhysicalMemory) / 1MB, 2)

    `$disk = Get-WmiObject Win32_LogicalDisk -Filter "DeviceID='C:'"
    `$diskTotalGB = [math]::Round([double]`$disk.Size / 1GB, 2)
    `$diskUsedGB  = [math]::Round(([double]`$disk.Size - [double]`$disk.FreeSpace) / 1GB, 2)

    # Uptime — wrap in try to handle WMI date conversion failures
    `$uptimeSec = try {
        [int]((Get-Date) - `$os.ConvertToDateTime(`$os.LastBootUpTime)).TotalSeconds
    } catch { 0 }

    # IP — force to plain string to avoid JSON array serialization
    `$ipObj = @(Get-WmiObject Win32_NetworkAdapterConfiguration |
        Where-Object { `$_.IPEnabled -and `$_.DefaultIPGateway } |
        Select-Object -First 1 |
        ForEach-Object { `$_.IPAddress | Where-Object { `$_ -notmatch ':' } }) |
        Select-Object -First 1
    `$ip = if (`$ipObj) { [string]`$ipObj } else { '' }

    Invoke-RestMethod -Uri "`$(`$config.server_url)/api/v1/mdm/windows/checkin" ``
        -Method POST -ContentType 'application/json' ``
        -Body (ConvertTo-Json @{
            device_id      = `$config.device_id
            agent_version  = '1.0.0'
            ip_address     = `$ip
            cpu_pct        = `$cpu
            ram_used_gb    = `$ramUsedGB
            ram_total_gb   = `$ramTotalGB
            disk_used_gb   = `$diskUsedGB
            disk_total_gb  = `$diskTotalGB
            uptime_seconds = `$uptimeSec
        } -Depth 3) | Out-Null
} catch {}
"@

$checkinScript | Set-Content -Path "$configDir\checkin.ps1" -Encoding UTF8

try {
{% if register_scheduled_task %}
    $action    = New-ScheduledTaskAction -Execute "powershell.exe" -Argument "-NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File ""$configDir\checkin.ps1"""
    $trigger   = New-ScheduledTaskTrigger -Once -At (Get-Date).AddMinutes(1) -RepetitionInterval (New-TimeSpan -Minutes 15)
    $principal = New-ScheduledTaskPrincipal -UserId "SYSTEM" -LogonType ServiceAccount -RunLevel Highest
    $settings  = New-ScheduledTaskSettingsSet -StartWhenAvailable -AllowStartIfOnBatteries -MissingOpportunity Automatic -ExecutionTimeLimit (New-TimeSpan -Minutes 5)

    Unregister-ScheduledTask -TaskName "{{ agent_display_name }} Check-In" -Confirm:$false -ErrorAction SilentlyContinue
    Register-ScheduledTask -TaskName "{{ agent_display_name }} Check-In" -Action $action -Trigger $trigger -Principal $principal -Settings $settings | Out-Null
    Write-Log "Scheduled task registered (every 15 min)"
{% else %}
    Write-Log "Scheduled task registration skipped as per package configuration."
{% endif %}
} catch {
    Write-Log "WARN: Could not register scheduled task: $_"
}

Write-Log "=== Enrollment complete! Device '$($env:COMPUTERNAME)' is now managed. ==="

{% if start_immediately %}
Write-Log "Start Immediately flag is set. Triggering initial check-in now..."
try {
    Start-Process powershell.exe -ArgumentList "-NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File ""$configDir\checkin.ps1""" -WindowStyle Hidden
} catch {
    Write-Log "WARN: Failed to start initial check-in: $_"
}
{% endif %}
