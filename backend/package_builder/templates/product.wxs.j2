<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
      Id="*"
      Name="{{ agent_display_name }} ({{ customer_name }})"
      Language="1033"
      Version="1.0.0"
      Manufacturer="NOCKO IT"
      UpgradeCode="{{ upgrade_guid }}">

    <!-- wixl does not support Platform="x64" on Package; use -a x64 CLI flag -->
    <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="{{ agent_display_name }}" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>

    <!--
      wixl (msitools on Linux) CANNOT produce working CustomActions.
      Tested: Directory-based, Property-based, deferred, commit — all fail silently.
      The ONLY proven approach is to use a RunOnce registry key (see below).
    -->

  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="NOCKO MDM" />
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="InstallScript" Guid="*" Win64="yes">
        <File Id="InstallPS1" Source="install.ps1" KeyPath="yes" />
      </Component>
      <Component Id="UninstallScript" Guid="*" Win64="yes">
        <File Id="UninstallPS1" Source="uninstall.ps1" KeyPath="yes" />
      </Component>
      <Component Id="ConfigFile" Guid="*" Win64="yes">
        <File Id="ConfigJSON" Source="config.json" KeyPath="yes" />
      </Component>
      <Component Id="ReadmeFile" Guid="*" Win64="yes">
        <File Id="ReadmeTXT" Source="README.txt" KeyPath="yes" />
      </Component>

      <!--
        RunOnce: Windows executes this command at the NEXT admin login,
        then automatically deletes the registry key.
        cmd /c start opens a VISIBLE black window so the user can see progress.
      -->
      <Component Id="RunOnceEnroll" Guid="*" Win64="yes">
        <RegistryValue Root="HKLM"
            Key="SOFTWARE\Microsoft\Windows\CurrentVersion\RunOnce"
            Name="NockoMDMEnroll"
            Type="string"
            Value="cmd.exe /c start &quot;NOCKO MDM Setup&quot; powershell.exe -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]install.ps1&quot;"
            KeyPath="yes" />
      </Component>

      <!-- App metadata in 64-bit registry -->
      <Component Id="RegistryExtras" Guid="*" Win64="yes">
        <RegistryValue Root="HKLM"
            Key="SOFTWARE\NOCKO IT\NOCKO MDM Agent"
            Name="MDMServer"     Type="string" Value="{{ server_url }}" KeyPath="yes" />
        <RegistryValue Root="HKLM"
            Key="SOFTWARE\NOCKO IT\NOCKO MDM Agent"
            Name="CustomerName"  Type="string" Value="{{ customer_name }}" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>

