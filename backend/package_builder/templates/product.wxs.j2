<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
      Id="*"
      Name="NOCKO MDM Agent ({{ customer_name }})"
      Language="1033"
      Version="1.0.0"
      Manufacturer="NOCKO IT"
      UpgradeCode="{{ upgrade_guid }}">

    <!-- FORCE 64-bit installer to prevent WOW6432Node registry redirection -->
    <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" Platform="x64" />
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="NOCKO MDM Agent" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>



  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="NOCKO MDM" />
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <!-- ALL components must be marked Win64="yes" for a 64-bit MSI -->
      <Component Id="InstallScript" Guid="*" Win64="yes">
        <File Id="InstallPS1" Source="install.ps1" KeyPath="yes" />
      </Component>
      <Component Id="UninstallScript" Guid="*" Win64="yes">
        <File Id="UninstallPS1" Source="uninstall.ps1" KeyPath="yes" />
      </Component>
      <Component Id="ConfigFile" Guid="*" Win64="yes">
        <File Id="ConfigJSON" Source="config.json" KeyPath="yes" />
      </Component>
      <Component Id="ReadmeFile" Guid="*" Win64="yes">
        <File Id="ReadmeTXT" Source="README.txt" KeyPath="yes" />
      </Component>

      <!--
        AUTO-ENROLL via RunOnce registry key.
        wixl (msitools) CustomActions are extremely unreliable for running PowerShell
        as SYSTEM. RunOnce tells Windows to reliably execute this command once at the 
        next admin login, and Windows automatically removes the key afterward.
      -->
      <Component Id="RunOnceEnroll" Guid="*" Win64="yes">
        <RegistryValue Root="HKLM"
            Key="SOFTWARE\Microsoft\Windows\CurrentVersion\RunOnce"
            Name="NockoMDMEnroll"
            Type="string"
            Value="powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass {% if install_mode == 'interactive' %}-WindowStyle Normal{% else %}-WindowStyle Hidden{% endif %} -File &quot;[INSTALLFOLDER]install.ps1&quot;"
            KeyPath="yes" />
      </Component>

      <!-- App metadata in strictly 64-bit registry (not WOW6432Node) -->
      <Component Id="RegistryExtras" Guid="*" Win64="yes">
        <RegistryValue Root="HKLM"
            Key="SOFTWARE\NOCKO IT\NOCKO MDM Agent"
            Name="MDMServer"     Type="string" Value="{{ server_url }}" KeyPath="yes" />
        <RegistryValue Root="HKLM"
            Key="SOFTWARE\NOCKO IT\NOCKO MDM Agent"
            Name="CustomerName"  Type="string" Value="{{ customer_name }}" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
