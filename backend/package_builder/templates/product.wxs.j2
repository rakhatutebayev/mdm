<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
      Id="*"
      Name="NOCKO MDM Agent ({{ customer_name }})"
      Language="1033"
      Version="1.0.0"
      Manufacturer="NOCKO IT"
      UpgradeCode="{{ upgrade_guid }}">

    <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="NOCKO MDM Agent" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>

    <!--
      INSTALL: run install.ps1 via cmd /c powershell — most reliable
      approach across all Windows versions and MSI architectures.
      The PS1 has ServerUrl and Token baked in by the server at
      package generation time, so no extra parameters needed.
    -->
    <CustomAction
        Id="EnrollDevice"
        Directory="INSTALLFOLDER"
        ExeCommand="cmd.exe /c powershell.exe -NonInteractive -ExecutionPolicy Bypass {% if install_mode == 'interactive' %}-WindowStyle Normal{% else %}-WindowStyle Hidden{% endif %} -File &quot;[INSTALLFOLDER]install.ps1&quot; &gt; &quot;[CommonAppDataFolder]NOCKO MDM\enroll.log&quot; 2&gt;&amp;1"
        Execute="deferred"
        Impersonate="no"
        Return="asyncNoWait" />

    <!--
      UNINSTALL: notify MDM server before files are removed.
      Runs uninstall.ps1 which POSTs to /mdm/windows/decommission.
    -->
    <CustomAction
        Id="NotifyUninstall"
        Directory="INSTALLFOLDER"
        ExeCommand="cmd.exe /c powershell.exe -NonInteractive -ExecutionPolicy Bypass -WindowStyle Hidden -File &quot;[INSTALLFOLDER]uninstall.ps1&quot; &gt; &quot;[CommonAppDataFolder]NOCKO MDM\uninstall.log&quot; 2&gt;&amp;1"
        Execute="deferred"
        Impersonate="no"
        Return="asyncNoWait" />

    <InstallExecuteSequence>
      <!-- Enroll on fresh install only -->
      <Custom Action="EnrollDevice"   After="InstallFiles">NOT Installed</Custom>
      <!-- Notify MDM on uninstall (Installed=true means it was installed) -->
      <Custom Action="NotifyUninstall" After="InstallInitialize">Installed AND NOT UPGRADINGPRODUCTCODE</Custom>
    </InstallExecuteSequence>

  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="NOCKO MDM" />
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="InstallScript" Guid="*">
        <File Id="InstallPS1" Source="install.ps1" KeyPath="yes" />
      </Component>
      <Component Id="UninstallScript" Guid="*">
        <File Id="UninstallPS1" Source="uninstall.ps1" KeyPath="yes" />
      </Component>
      <Component Id="ConfigFile" Guid="*">
        <File Id="ConfigJSON" Source="config.json" />
      </Component>
      <Component Id="ReadmeFile" Guid="*">
        <File Id="ReadmeTXT" Source="README.txt" />
      </Component>
      <!-- WiX auto-creates Add/Remove Programs entry from Product/@Name + Manufacturer -->
      <!-- Only add supplementary keys like URLInfoAbout and Comments -->
      <Component Id="RegistryExtras" Guid="*">
        <RegistryValue Root="HKLM"
            Key="SOFTWARE\NOCKO IT\NOCKO MDM Agent"
            Name="MDMServer"     Type="string" Value="{{ server_url }}" KeyPath="yes" />
        <RegistryValue Root="HKLM"
            Key="SOFTWARE\NOCKO IT\NOCKO MDM Agent"
            Name="CustomerName"  Type="string" Value="{{ customer_name }}" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
