<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
      Id="*"
      Name="{{ agent_display_name }} ({{ customer_name }})"
      Language="1033"
      Version="1.0.0"
      Manufacturer="NOCKO IT"
      UpgradeCode="{{ upgrade_guid }}">

    <!-- wixl does not support Platform="x64" on Package; use -a x64 CLI flag -->
    <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="{{ agent_display_name }}" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>

    <!--
      Property-based CustomAction (Type 50).
      wixl does NOT support Directory= on CustomAction, but supports Property=.
      We set POWERSHELLEXE to the full path of powershell.exe.
      Execute="commit" runs AFTER the install transaction commits (files on disk).
      Impersonate="yes" runs in the user's interactive desktop session (visible).
    -->
    <Property Id="POWERSHELLEXE" Value="C:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe" />

    <CustomAction
        Id="EnrollDevice"
        Property="POWERSHELLEXE"
        ExeCommand="-NoProfile -ExecutionPolicy Bypass -WindowStyle Normal -File &quot;[INSTALLFOLDER]install.ps1&quot;"
        Execute="commit"
        Impersonate="yes"
        Return="ignore" />

    <CustomAction
        Id="NotifyUninstall"
        Property="POWERSHELLEXE"
        ExeCommand="-NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File &quot;[INSTALLFOLDER]uninstall.ps1&quot;"
        Execute="commit"
        Impersonate="yes"
        Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="EnrollDevice"   After="InstallFiles">NOT Installed</Custom>
      <Custom Action="NotifyUninstall" Before="RemoveFiles">Installed AND NOT UPGRADINGPRODUCTCODE</Custom>
    </InstallExecuteSequence>

  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="NOCKO MDM" />
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="InstallScript" Guid="*" Win64="yes">
        <File Id="InstallPS1" Source="install.ps1" KeyPath="yes" />
      </Component>
      <Component Id="UninstallScript" Guid="*" Win64="yes">
        <File Id="UninstallPS1" Source="uninstall.ps1" KeyPath="yes" />
      </Component>
      <Component Id="ConfigFile" Guid="*" Win64="yes">
        <File Id="ConfigJSON" Source="config.json" KeyPath="yes" />
      </Component>
      <Component Id="ReadmeFile" Guid="*" Win64="yes">
        <File Id="ReadmeTXT" Source="README.txt" KeyPath="yes" />
      </Component>

      <!-- App metadata in 64-bit registry -->
      <Component Id="RegistryExtras" Guid="*" Win64="yes">
        <RegistryValue Root="HKLM"
            Key="SOFTWARE\NOCKO IT\NOCKO MDM Agent"
            Name="MDMServer"     Type="string" Value="{{ server_url }}" KeyPath="yes" />
        <RegistryValue Root="HKLM"
            Key="SOFTWARE\NOCKO IT\NOCKO MDM Agent"
            Name="CustomerName"  Type="string" Value="{{ customer_name }}" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>

