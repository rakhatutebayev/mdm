<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
      Id="*"
      Name="NOCKO MDM Agent ({{ customer_name }})"
      Language="1033"
      Version="1.0.0"
      Manufacturer="NOCKO IT"
      UpgradeCode="{{ upgrade_guid }}">

    <Package InstallerVersion="200" Compressed="yes" InstallScope="perMachine" />
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="NOCKO MDM Agent" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>

    <!--
      INSTALL: Run the PowerShell script directly without cmd.exe redirection.
      Redirection to [CommonAppDataFolder]NOCKO MDM\enroll.log would fail because
      the directory doesn't exist yet (the PS1 script creates it itself).
    -->
    <CustomAction
        Id="EnrollDevice"
        Directory="INSTALLFOLDER"
        ExeCommand="powershell.exe -NonInteractive -ExecutionPolicy Bypass {% if install_mode == 'interactive' %}-WindowStyle Normal{% else %}-WindowStyle Hidden{% endif %} -File &quot;[INSTALLFOLDER]install.ps1&quot;"
        Execute="deferred"
        Impersonate="no"
        Return="asyncNoWait" />

    <CustomAction
        Id="NotifyUninstall"
        Directory="INSTALLFOLDER"
        ExeCommand="powershell.exe -NonInteractive -ExecutionPolicy Bypass -WindowStyle Hidden -File &quot;[INSTALLFOLDER]uninstall.ps1&quot;"
        Execute="deferred"
        Impersonate="no"
        Return="asyncNoWait" />

    <InstallExecuteSequence>
      <!-- Enroll on fresh install only -->
      <Custom Action="EnrollDevice"   After="InstallFiles">NOT Installed</Custom>
      <!-- Notify MDM on uninstall -->
      <Custom Action="NotifyUninstall" Before="RemoveFiles">Installed AND NOT UPGRADINGPRODUCTCODE</Custom>
    </InstallExecuteSequence>

  </Product>

  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="NOCKO MDM" />
      </Directory>
    </Directory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="InstallScript" Guid="*">
        <File Id="InstallPS1" Source="install.ps1" KeyPath="yes" />
      </Component>
      <Component Id="UninstallScript" Guid="*">
        <File Id="UninstallPS1" Source="uninstall.ps1" KeyPath="yes" />
      </Component>
      <Component Id="ConfigFile" Guid="*">
        <File Id="ConfigJSON" Source="config.json" KeyPath="yes" />
      </Component>
      <Component Id="ReadmeFile" Guid="*">
        <File Id="ReadmeTXT" Source="README.txt" KeyPath="yes" />
      </Component>

      <!-- App metadata in our own registry key -->
      <Component Id="RegistryExtras" Guid="*">
        <RegistryValue Root="HKLM"
            Key="SOFTWARE\NOCKO IT\NOCKO MDM Agent"
            Name="MDMServer"     Type="string" Value="{{ server_url }}" KeyPath="yes" />
        <RegistryValue Root="HKLM"
            Key="SOFTWARE\NOCKO IT\NOCKO MDM Agent"
            Name="CustomerName"  Type="string" Value="{{ customer_name }}" />
      </Component>

    </ComponentGroup>
  </Fragment>
</Wix>
