; NOCKO MDM Agent Setup
; Generated by NOCKO MDM Server — do not edit manually.

!define APPNAME    "{{ agent_display_name }}"
!define COMPANY    "NOCKO IT"
!define CUSTOMER   "{{ customer_name }}"
!define APPVERSION "1.0.0"
!define PUBLISHER  "NOCKO IT"
!define REG_KEY    "Software\Microsoft\Windows\CurrentVersion\Uninstall\NOCKOMDM"
!define TASK_NAME  "{{ agent_display_name }} Check-In"

; SetRegView 64 is called inside Section and Function blocks below

Name      "${APPNAME} (${CUSTOMER})"
OutFile   "setup.exe"
InstallDir "{{ install_dir }}"
RequestExecutionLevel admin
SetCompressor /SOLID lzma
Unicode true

!include "MUI2.nsh"
!include "FileFunc.nsh"
!include "AccessControl.nsh"

; ── MUI Pages ────────────────────────────────────────────────────────────────
!define MUI_ABORTWARNING
!define MUI_ICON   "${NSISDIR}\Contrib\Graphics\Icons\modern-install.ico"
!define MUI_UNICON "${NSISDIR}\Contrib\Graphics\Icons\modern-uninstall.ico"
!define MUI_WELCOMEPAGE_TITLE  "Welcome to NOCKO MDM Agent Setup"
!define MUI_WELCOMEPAGE_TEXT   "This wizard will enroll your device into NOCKO MDM for customer:$\n$\n${CUSTOMER}$\n$\nClick Next to continue."

!insertmacro MUI_PAGE_WELCOME
!insertmacro MUI_PAGE_LICENSE "README.txt"
!insertmacro MUI_PAGE_INSTFILES
!insertmacro MUI_PAGE_FINISH
!insertmacro MUI_UNPAGE_CONFIRM
!insertmacro MUI_UNPAGE_INSTFILES
!insertmacro MUI_LANGUAGE "English"

; ── Silent / Interactive mode ────────────────────────────────────────────────
{% if install_mode == 'interactive' %}
Function .onInit
    SetRegView 64
    ; Interactive: show MUI wizard — auto-remove previous version first
    ReadRegStr $R0 HKLM "${REG_KEY}" "UninstallString"
    StrCmp $R0 "" done_uninstall
    ExecWait '"$R0" /S'
    Sleep 1000
    done_uninstall:
FunctionEnd
{% else %}
Function .onInit
    SetRegView 64
    SetSilent silent
    ; Silent: also auto-remove previous version
    ReadRegStr $R0 HKLM "${REG_KEY}" "UninstallString"
    StrCmp $R0 "" done_uninstall
    ExecWait '"$R0" /S'
    Sleep 1000
    done_uninstall:
FunctionEnd
{% endif %}

; ── Installer ─────────────────────────────────────────────────────────────────
Section "MainSection" SEC01
    SetRegView 64
    SetOutPath "$INSTDIR"

    ; Write files to ProgramFiles
    File "install.ps1"
    File "config.json"
    File "README.txt"

    ; Set up config directory
    CreateDirectory "{{ log_dir }}"
    AccessControl::GrantOnFile "{{ log_dir }}" "(S-1-5-32-545)" "FullAccess"

    ; Run enrollment PowerShell script
    ; Use cmd /c to handle paths with spaces correctly
    DetailPrint "Enrolling device with NOCKO MDM..."
    nsExec::ExecToLog 'cmd.exe /C "PowerShell.exe -NonInteractive -ExecutionPolicy Bypass {% if install_mode == "interactive" %}-WindowStyle Normal{% else %}-WindowStyle Hidden{% endif %} -File ""$INSTDIR\install.ps1"" >> ""{{ log_dir }}\enroll.log"" 2>&1"'
    Pop $0
    ${If} $0 != 0
        MessageBox MB_ICONEXCLAMATION "Enrollment encountered an issue (exit code: $0).$\nCheck {{ log_dir }}\enroll.log for details."
    ${Else}
        DetailPrint "Enrollment completed!"
    ${EndIf}

    ; Write uninstaller
    WriteUninstaller "$INSTDIR\Uninstall.exe"

    ; Registry uninstall entry (64-bit view set at top)
    WriteRegStr HKLM "${REG_KEY}" "DisplayName"     "${APPNAME} (${CUSTOMER})"
    WriteRegStr HKLM "${REG_KEY}" "UninstallString"  "$\"$INSTDIR\Uninstall.exe$\""
    WriteRegStr HKLM "${REG_KEY}" "QuietUninstallString" "$\"$INSTDIR\Uninstall.exe$\" /S"
    WriteRegStr HKLM "${REG_KEY}" "DisplayVersion"   "${APPVERSION}"
    WriteRegStr HKLM "${REG_KEY}" "Publisher"        "${PUBLISHER}"
    WriteRegStr HKLM "${REG_KEY}" "InstallLocation"  "$INSTDIR"
    WriteRegStr HKLM "${REG_KEY}" "DisplayIcon"      "$INSTDIR\Uninstall.exe"
    WriteRegDWORD HKLM "${REG_KEY}" "NoModify"       1
    WriteRegDWORD HKLM "${REG_KEY}" "NoRepair"       1
SectionEnd

; ── Uninstaller ───────────────────────────────────────────────────────────────
Section "Uninstall"
    SetRegView 64
    ; Remove scheduled task
    nsExec::ExecToLog 'schtasks /Delete /TN "${TASK_NAME}" /F'

    ; Remove files from ProgramFiles
    Delete "$INSTDIR\install.ps1"
    Delete "$INSTDIR\config.json"
    Delete "$INSTDIR\README.txt"
    Delete "$INSTDIR\Uninstall.exe"
    RMDir  "$INSTDIR"

    ; Ask user whether to remove ProgramData config (keeps logs/history if no)
    MessageBox MB_YESNO "Remove device configuration from {{ log_dir }}?$\n(This removes enrollment info and logs)" IDNO skip_config
        Delete "{{ log_dir }}\config.json"
        Delete "{{ log_dir }}\checkin.ps1"
        Delete "{{ log_dir }}\enroll.log"
        Delete "{{ log_dir }}\uninstall.log"
        RMDir  "{{ log_dir }}"
    skip_config:

    ; Remove registry entry
    DeleteRegKey HKLM "${REG_KEY}"

    MessageBox MB_OK "NOCKO MDM Agent has been removed from this device.$\nThe device will no longer report to the MDM server."
SectionEnd
