{
  "portal_url": "https://portal.example.com",
  "agent_id": "REPLACE_WITH_PORTAL_AGENT_ID",
  "agent_token": "proxy-REPLACE_ME",
  "agent_name": "HQ Proxy Agent",
  "site_name": "HQ",
  "hostname": "proxy-branch-01",
  "ip_address": "192.168.11.153",
  "version": "0.1.0",
  "interval_seconds": 300,
  "request_timeout_seconds": 30,
  "mqtt_enabled": true,
  "mqtt_host": "",
  "mqtt_port": 443,
  "mqtt_transport": "websockets",
  "mqtt_path": "/mqtt",
  "mqtt_tls": true,
  "mqtt_tls_verify": true,
  "mqtt_tls_allow_insecure_fallback": false,
  "mqtt_heartbeat_interval_seconds": 30,
  "collectors_enabled": ["snmp", "redfish", "lldp"],
  "collectors": {
    "snmp_targets": [
      {
        "name": "Avaya phones",
        "subnet": "192.168.11.0/24",
        "community": "nocko1608ro",
        "port": 161,
        "timeout": 0.8,
        "retries": 0,
        "workers": 32,
        "template_key": "avaya_1608",
        "only_match": "avaya"
      },
      {
        "name": "iDRAC",
        "hosts": ["192.168.11.219"],
        "community": "public",
        "port": 161,
        "timeout": 1.0,
        "retries": 1,
        "workers": 8,
        "template_key": "dell_idrac",
        "idrac_storage_enabled": true,
        "storage_timeout_s": 4.0
      },
      {
        "name": "ESXi host",
        "hosts": ["192.168.11.151"],
        "community": "public",
        "port": 161,
        "timeout": 1.5,
        "retries": 1,
        "workers": 4,
        "template_key": "vmware_esxi",
        "ssh_username": "root",
        "ssh_password": "CHANGE_ME",
        "ssh_port": 22,
        "perccli_path": "/opt/lsi/perccli/perccli",
        "perccli_controller": 0
      }
    ],
    "redfish_targets": [
      {
        "name": "iDRAC Redfish",
        "base_url": "https://192.168.11.219",
        "username": "root",
        "password": "CHANGE_ME",
        "verify_tls": false,
        "timeout": 10,
        "template_key": "dell_idrac_redfish"
      }
    ]
  }
}
