# Copy this file to .env and fill in real values before running docker compose.
# Never commit .env with real secrets.

# PostgreSQL password — required, no default
POSTGRES_PASSWORD=change_me_strong_password

# JWT secret key — required, generate with: openssl rand -hex 32
SECRET_KEY=change_me_run_openssl_rand_hex_32

# Portal admin account (created automatically on first start)
ADMIN_EMAIL=admin@nocko.com
ADMIN_PASSWORD=change_me_admin_password

# Public URL of the MDM server (used for agent download links etc.)
MDM_SERVER_URL=https://mdm.example.com

# Set to true when serving over HTTPS (production). false for local HTTP testing.
SECURE_COOKIES=true

# CORS — comma-separated list of allowed origins (leave empty to allow all, NOT recommended for production)
# Example: ALLOWED_ORIGINS=https://mdm.example.com,https://admin.example.com
ALLOWED_ORIGINS=

# MQTT broker settings (defaults work when using docker-compose.mqtt.yml)
MQTT_HOST=emqx
MQTT_PORT=8083
MQTT_TRANSPORT=websockets
MQTT_PATH=/mqtt

# MQTT credentials — used by backend AND written into agent config at enrollment
# Must be set; emqx-setup creates this user automatically on first start
MQTT_USERNAME=nocko_backend
MQTT_PASSWORD=change_me_mqtt_password

# EMQX dashboard admin password (localhost:18083)
EMQX_DASHBOARD_PASSWORD=change_me_dashboard_password

# Set to false only for development with self-signed VMware certs
VMWARE_TLS_VERIFY=true

# EMQX anonymous auth — must be false in production; set to true only for local dev
EMQX_ALLOW_ANONYMOUS=false
