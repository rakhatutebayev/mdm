# .env example - copy to .env and fill in real values
SECRET_KEY=your-secret-key-change-in-production

# Database
POSTGRES_USER=mdm
POSTGRES_PASSWORD=mdm_secret
POSTGRES_DB=nocko_mdm

# Redis
REDIS_URL=redis://redis:6379/0

# Apple MDM
APPLE_PUSH_CERT_PATH=/app/certs/apple_push.pem
APPLE_PUSH_KEY_PATH=/app/certs/apple_push.key
APPLE_MDM_TOPIC=com.apple.mgmt.External.your-mdm-uuid
APPLE_DEP_TOKEN_PATH=/app/certs/dep_token.p7m
APPLE_DEP_SERVER_TOKEN_PATH=/app/certs/dep_server_token.json

# Android Enterprise
GOOGLE_SERVICE_ACCOUNT_JSON=/app/certs/google_service_account.json
ANDROID_ENTERPRISE_ID=your-enterprise-id

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# MDM Server URL (public HTTPS URL for Apple MDM check-in)
MDM_SERVER_URL=https://mdm.yourdomain.com
ENROLLMENT_URL=https://mdm.yourdomain.com/api/v1/enrollment
